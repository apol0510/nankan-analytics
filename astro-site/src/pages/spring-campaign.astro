---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="春の特別キャンペーン - NANKANアナリティクス">
    <div class="campaign-page">
        <!-- キャンペーンヘッダー -->
        <div class="campaign-header">
            <div class="campaign-badge">🌸 春の特別キャンペーン 🌸</div>
            <h1 class="campaign-title">
                <span class="gradient-text">期間限定</span>
                <br>プレミアム買い切りプラン
            </h1>
            <p class="campaign-subtitle">
                永久アクセス権を特別価格でご提供
            </p>

            <!-- カウントダウンタイマー -->
            <div class="countdown-container">
                <div class="countdown-title">⏰ 残り時間</div>
                <div class="countdown-timer" id="countdown">
                    <div class="countdown-item">
                        <span class="countdown-value" id="hours">00</span>
                        <span class="countdown-label">時間</span>
                    </div>
                    <div class="countdown-separator">:</div>
                    <div class="countdown-item">
                        <span class="countdown-value" id="minutes">00</span>
                        <span class="countdown-label">分</span>
                    </div>
                    <div class="countdown-separator">:</div>
                    <div class="countdown-item">
                        <span class="countdown-value" id="seconds">00</span>
                        <span class="countdown-label">秒</span>
                    </div>
                </div>
                <p class="countdown-note">※3月18日23:59まで</p>
            </div>
        </div>

        <!-- 価格カード -->
        <div class="price-card-container">
            <div class="price-card">
                <!-- 限定バッジ -->
                <div class="limited-badge">
                    <span>🔥 期間限定</span>
                </div>

                <div class="price-header">
                    <h2 class="plan-name">プレミアム買い切り</h2>
                    <div class="price-display">
                        <div class="price-comparison">
                            <div class="original-price">
                                <span class="price-label">通常価格</span>
                                <span class="price-value strike">¥108,000</span>
                            </div>
                            <div class="arrow-down">↓</div>
                            <div class="campaign-price">
                                <span class="price-label">期間限定価格</span>
                                <span class="price-value highlight">¥49,800</span>
                            </div>
                        </div>
                        <div class="price-save">58,200円もお得！</div>
                        <div class="price-period">永久アクセス権</div>
                    </div>
                </div>

                <!-- 特典リスト -->
                <div class="benefits-section">
                    <h3 class="benefits-title">✨ プレミアム特典</h3>
                    <ul class="benefits-list">
                        <li class="benefit-item">
                            <span class="check-icon">✓</span>
                            <span><strong>永久アクセス（追加料金なし）</strong></span>
                        </li>
                        <li class="benefit-item">
                            <span class="check-icon">✓</span>
                            <span><strong>全レース（1R〜12R）の予想</strong></span>
                        </li>
                        <li class="benefit-item">
                            <span class="check-icon">✓</span>
                            <span>高精度AI予想</span>
                        </li>
                        <li class="benefit-item">
                            <span class="check-icon">✓</span>
                            <span>詳細な投資戦略</span>
                        </li>
                        <li class="benefit-item">
                            <span class="check-icon">✓</span>
                            <span>優先サポート</span>
                        </li>
                        <li class="benefit-item">
                            <span class="check-icon">✓</span>
                            <span>今後のアップデートも永久無料</span>
                        </li>
                    </ul>
                </div>

                <!-- CTAボタン -->
                <button class="cta-button" onclick="openBankModal('Premium Lifetime - Spring Campaign', 49800, 'lifetime')">
                    🏦 今すぐ申し込む
                </button>

                <div class="security-note">
                    🔒 銀行振込で安全にお支払い
                </div>
            </div>
        </div>

        <!-- なぜ今なのか -->
        <div class="why-now-section">
            <h2 class="section-title">なぜ期間限定なのか？</h2>
            <div class="why-now-grid">
                <div class="why-now-card">
                    <div class="why-now-icon">🌸</div>
                    <h3>春の感謝キャンペーン</h3>
                    <p>日頃のご愛顧に感謝して、期間限定で特別価格をご用意しました。</p>
                </div>
                <div class="why-now-card">
                    <div class="why-now-icon">⚡</div>
                    <h3>すぐに使える</h3>
                    <p>入金確認後、即座にアクセス権をお渡しします。明日のレースから使えます。</p>
                </div>
                <div class="why-now-card">
                    <div class="why-now-icon">📈</div>
                    <h3>AIは毎日進化</h3>
                    <p>早く始めるほど、進化し続けるAIの恩恵を長く受けられます。</p>
                </div>
            </div>
        </div>

        <!-- 価格比較 -->
        <div class="comparison-section">
            <h2 class="section-title">他プランとの比較</h2>
            <div class="comparison-table">
                <div class="comparison-row comparison-header">
                    <div class="comparison-cell">プラン</div>
                    <div class="comparison-cell">価格</div>
                    <div class="comparison-cell">5年間の総額</div>
                </div>
                <div class="comparison-row highlight-row">
                    <div class="comparison-cell"><strong>買い切り（期間限定）</strong></div>
                    <div class="comparison-cell"><strong>¥49,800</strong></div>
                    <div class="comparison-cell"><strong>¥49,800</strong></div>
                </div>
                <div class="comparison-row">
                    <div class="comparison-cell">買い切り（通常）</div>
                    <div class="comparison-cell">¥108,000</div>
                    <div class="comparison-cell">¥108,000</div>
                </div>
                <div class="comparison-row">
                    <div class="comparison-cell">年払いプラン</div>
                    <div class="comparison-cell">¥68,000/年</div>
                    <div class="comparison-cell">¥340,000</div>
                </div>
                <div class="comparison-row">
                    <div class="comparison-cell">月払いプラン</div>
                    <div class="comparison-cell">¥18,000/月</div>
                    <div class="comparison-cell">¥1,080,000</div>
                </div>
            </div>
            <p class="comparison-note">
                ※ 5年間使うと仮定した場合、期間限定プランは<strong>月額換算で約¥830</strong>です。
            </p>
        </div>

        <!-- FAQ -->
        <div class="faq-section">
            <h2 class="section-title">よくある質問</h2>

            <div class="faq-container">
                <div class="faq-item">
                    <h3 class="faq-question">Q: 本当に永久に使えますか？</h3>
                    <p class="faq-answer">
                        はい。一度ご購入いただければ、追加料金なしで永久にご利用いただけます。
                        AIは毎日進化し続けるため、長く使うほどお得になります。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 通常の¥108,000プランとの違いは？</h3>
                    <p class="faq-answer">
                        サービス内容は全く同じです。期間限定で特別価格でご提供しているだけです。
                        機能面での制限は一切ありません。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 支払い方法は？</h3>
                    <p class="faq-answer">
                        銀行振込のみ対応しております。振込後、入金確認取れ次第、
                        即時にログイン情報をメールでお送りいたします。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 期間内に振込できなかった場合は？</h3>
                    <p class="faq-answer">
                        申し訳ございませんが、本キャンペーンは3月18日23:59までの申し込み分のみ有効です。
                        期間終了後は通常価格（¥108,000）での販売となります。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 既に他のプランを利用中ですが、乗り換えできますか？</h3>
                    <p class="faq-answer">
                        はい、可能です。備考欄に現在のプラン情報をご記入ください。
                        個別に対応させていただきます。
                    </p>
                </div>
            </div>
        </div>

        <!-- 最終CTA -->
        <div class="final-cta-section">
            <div class="final-cta-card">
                <h2 class="final-cta-title">今すぐ始めて、勝ち続ける</h2>
                <p class="final-cta-text">
                    このチャンスは3月18日まで。<br>
                    58,200円の割引は二度とありません。
                </p>
                <div class="final-price">
                    <span class="final-price-strike">¥108,000</span>
                    <span class="final-price-arrow">→</span>
                    <span class="final-price-value">¥49,800</span>
                </div>
                <button class="cta-button large" onclick="openBankModal('Premium Lifetime - Spring Campaign', 49800, 'lifetime')">
                    🏦 今すぐ申し込む
                </button>
                <p class="final-cta-note">
                    ⏰ 残り時間わずか・3月18日23:59まで
                </p>
            </div>
        </div>
    </div>

    <!-- 銀行振込モーダル -->
    <div class="bank-modal" id="bankModal">
      <div class="bank-modal-content">
        <button class="bank-modal-close" onclick="closeBankModal()">×</button>

        <h2 class="bank-modal-title">🏦 銀行振込でのお申し込み</h2>
        <p class="modal-plan-info" id="modalPlanInfo"></p>

        <div class="bank-info-box">
          <div class="bank-info-item">
            <span class="bank-info-label">振込先銀行</span>
            <span class="bank-info-value">三井住友銀行
              <button class="copy-button" onclick="copyToClipboard('三井住友銀行')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">支店名</span>
            <span class="bank-info-value">洲本支店
              <button class="copy-button" onclick="copyToClipboard('洲本支店')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">口座種別</span>
            <span class="bank-info-value">普通</span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">口座番号</span>
            <span class="bank-info-value">5338892
              <button class="copy-button" onclick="copyToClipboard('5338892')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">口座名義</span>
            <span class="bank-info-value" style="font-size: 0.95rem;">ﾏ-ｸｱﾂﾌﾟｴ-ｱｲｻ-ﾋﾞｽ ｱｻｲ ﾄｼﾋﾛ
              <button class="copy-button" onclick="copyToClipboard('ﾏ-ｸｱﾂﾌﾟｴ-ｱｲｻ-ﾋﾞｽ ｱｻｲ ﾄｼﾋﾛ')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3);">
            <span class="bank-info-label">振込金額</span>
            <span class="bank-info-value" style="color: #10b981; font-size: 1.3rem;" id="modalAmount">¥49,800</span>
          </div>
        </div>

        <div class="bank-steps">
          <div class="bank-steps-title">📝 お申し込み手順</div>
          <div class="bank-step">
            <span class="bank-step-number">1</span>
            <span>上記の口座情報に振込金額をお振込みください</span>
          </div>
          <div class="bank-step">
            <span class="bank-step-number">2</span>
            <span>振込完了後、下記のフォームから必要情報をご送信ください</span>
          </div>
          <div class="bank-step">
            <span class="bank-step-number">3</span>
            <span>入金確認取れ次第、即時にログイン情報をメールでお送りいたします</span>
          </div>
        </div>

        <!-- 銀行振込申し込みフォーム -->
        <div class="bank-form-section">
          <div class="bank-form-title">💳 銀行振込完了フォーム</div>

          <form id="bankTransferForm" class="bank-form">
            <div class="form-group">
              <label for="fullName" class="form-label">お名前 <span class="required">*</span></label>
              <input type="text" id="fullName" name="fullName" class="form-input" required placeholder="山田 太郎">
            </div>

            <div class="form-group">
              <label for="email" class="form-label">メールアドレス <span class="required">*</span></label>
              <input type="email" id="email" name="email" class="form-input" required placeholder="example@email.com">
            </div>

            <div class="form-group">
                <label for="transferDate" class="form-label">振込完了日 <span class="required">*</span></label>
                <input type="date" id="transferDate" name="transferDate" class="form-input" required>
              </div>

            <div class="form-group">
              <label for="transferAmount" class="form-label">振込金額 <span class="required">*</span></label>
              <input type="number" id="transferAmount" name="transferAmount" class="form-input" required readonly>
            </div>

            <div class="form-group">
              <label for="remarks" class="form-label">備考・ご要望</label>
              <textarea id="remarks" name="remarks" class="form-input" rows="3" placeholder="何かご要望がありましたらご記入ください（任意）"></textarea>
            </div>

            <button type="submit" class="form-submit-button" id="submitButton">
              <span class="submit-text">📨 申し込みを送信</span>
              <span class="submit-loading" style="display: none;">送信中...</span>
            </button>

            <div class="form-message" id="formMessage" style="display: none;"></div>
          </form>
        </div>

        <div class="bank-warning">
          <div class="bank-warning-title">⚠️ ご注意事項</div>
          <div class="bank-warning-text">
            ・振込手数料はお客様負担となります<br>
            ・土日祝日の場合、確認が翌営業日となる場合がございます<br>
            ・<strong>お名前と同じ名義で振込をお願いします</strong><br>
            ・名義が異なる場合は、備考欄にその旨をご記入ください<br>
            ・ご入金後のキャンセル・返金は承っておりません
          </div>
        </div>
      </div>
    </div>
</BaseLayout>

<script is:inline>
  // カウントダウンタイマー
  function updateCountdown() {
    const now = new Date();
    // 3月18日 23:59:59 に設定
    const endDate = new Date('2026-03-18T23:59:59+09:00');

    const diff = endDate - now;

    if (diff <= 0) {
      document.getElementById('hours').textContent = '00';
      document.getElementById('minutes').textContent = '00';
      document.getElementById('seconds').textContent = '00';
      return;
    }

    const hours = Math.floor(diff / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    document.getElementById('hours').textContent = String(hours).padStart(2, '0');
    document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
    document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
  }

  // 1秒ごとに更新
  setInterval(updateCountdown, 1000);
  updateCountdown(); // 初回実行

  // モーダル処理
  let currentPlan = '';
  let currentAmount = 0;
  let currentPlanType = 'lifetime';

  function openBankModal(planName, amount, planType = 'lifetime') {
    currentPlan = planName;
    currentAmount = amount;
    currentPlanType = planType;

    document.getElementById('modalPlanInfo').textContent = `プラン: ${planName} (¥${amount.toLocaleString()}・永久アクセス)`;
    document.getElementById('modalAmount').textContent = `¥${amount.toLocaleString()}`;
    document.getElementById('transferAmount').value = amount;
    document.getElementById('bankModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeBankModal() {
    document.getElementById('bankModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function copyToClipboard(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();

    try {
      document.execCommand('copy');
      alert('コピーしました: ' + text);
    } catch (err) {
      console.error('コピーに失敗しました:', err);
    }

    document.body.removeChild(textarea);
  }

  // DOMContentLoaded後にフォーム処理を登録
  document.addEventListener('DOMContentLoaded', () => {
    // モーダル外クリックで閉じる
    document.addEventListener('click', (e) => {
      const bankModal = document.getElementById('bankModal');
      if (e.target === bankModal) {
        closeBankModal();
      }
    });

    // Escapeキーで閉じる
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeBankModal();
      }
    });

    // 銀行振込フォーム送信処理
    const bankTransferForm = document.getElementById('bankTransferForm');
    if (bankTransferForm) {
      bankTransferForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitButton = document.getElementById('submitButton');
        const submitText = submitButton.querySelector('.submit-text');
        const submitLoading = submitButton.querySelector('.submit-loading');
        const formMessage = document.getElementById('formMessage');

        submitButton.disabled = true;
        submitText.style.display = 'none';
        submitLoading.style.display = 'inline';
        formMessage.style.display = 'none';

        const formData = {
          fullName: document.getElementById('fullName').value,
          email: document.getElementById('email').value,
          transferDate: document.getElementById('transferDate').value,
          transferTime: "00:00",
          transferAmount: document.getElementById('transferAmount').value,
          transferName: document.getElementById('fullName').value,
          remarks: document.getElementById('remarks').value,
          productName: `${currentPlan} (¥${currentAmount.toLocaleString()}・永久アクセス)`,
          timestamp: new Date().toISOString()
        };

        try {
          const response = await fetch('/.netlify/functions/bank-transfer-application', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
            formMessage.textContent = '✅ お申し込みを受け付けました。確認メールをお送りしましたのでご確認ください。';
            formMessage.className = 'form-message success';
            formMessage.style.display = 'block';

            document.getElementById('bankTransferForm').reset();

            setTimeout(() => {
              closeBankModal();
              formMessage.style.display = 'none';
            }, 3000);
          } else {
            throw new Error(result.error || '送信に失敗しました');
          }
        } catch (error) {
          formMessage.textContent = '❌ エラーが発生しました: ' + error.message;
          formMessage.className = 'form-message error';
          formMessage.style.display = 'block';
        } finally {
          submitButton.disabled = false;
          submitText.style.display = 'inline';
          submitLoading.style.display = 'none';
        }
      });
    }
  });
</script>

<style>
    .campaign-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: #e2e8f0;
        padding: 2rem 1rem;
    }

    /* キャンペーンヘッダー */
    .campaign-header {
        text-align: center;
        margin-bottom: 4rem;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .campaign-badge {
        display: inline-block;
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 9999px;
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 2rem;
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }

    .campaign-title {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 1rem;
        line-height: 1.2;
    }

    .gradient-text {
        background: linear-gradient(to right, #f59e0b, #ef4444);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
    }

    .campaign-subtitle {
        font-size: 1.5rem;
        color: #94a3b8;
        margin-bottom: 3rem;
    }

    /* カウントダウンタイマー */
    .countdown-container {
        background: rgba(239, 68, 68, 0.1);
        border: 2px solid rgba(239, 68, 68, 0.3);
        border-radius: 1rem;
        padding: 2rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .countdown-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #ef4444;
        margin-bottom: 1rem;
    }

    .countdown-timer {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .countdown-item {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .countdown-value {
        font-size: 3rem;
        font-weight: 700;
        color: #ef4444;
        line-height: 1;
        font-family: 'Courier New', monospace;
    }

    .countdown-label {
        font-size: 0.9rem;
        color: #94a3b8;
        margin-top: 0.5rem;
    }

    .countdown-separator {
        font-size: 2.5rem;
        color: #ef4444;
        font-weight: 700;
    }

    .countdown-note {
        color: #cbd5e1;
        font-size: 1rem;
        margin: 0;
    }

    /* 価格カード */
    .price-card-container {
        max-width: 700px;
        margin: 0 auto 4rem auto;
    }

    .price-card {
        background: rgba(30, 41, 59, 0.9);
        border: 3px solid #f59e0b;
        border-radius: 2rem;
        padding: 3rem;
        position: relative;
        box-shadow: 0 20px 60px rgba(245, 158, 11, 0.3);
    }

    .limited-badge {
        position: absolute;
        top: -1.5rem;
        left: 50%;
