// Standard会員向け1段構成買い目生成関数（本命軸 or 対抗軸の自動判定）
function generateOneLineUmatanBets(horses) {
    // 配列チェック
    if (!Array.isArray(horses) || horses.length === 0) return null;

    // 本命と対抗を特定
    const honmei = horses.find(h => h.role === '本命');
    const taikou = horses.find(h => h.role === '対抗');

    if (!honmei) return null;

    // 本命と対抗の点数差を確認（2ポイント以内なら対抗軸に切り替え）
    let axisHorse = honmei;
    let axisLabel = '本命';

    if (taikou && honmei.score && taikou.score) {
        const scoreDiff = honmei.score - taikou.score;
        if (scoreDiff <= 2) {
            axisHorse = taikou;
            axisLabel = '対抗';
            console.log(`🔄 軸を対抗に変更: 本命${honmei.score}点 vs 対抗${taikou.score}点 (差${scoreDiff}点)`);
        }
    }

    // 相手馬を馬番順に並べる（軸馬以外を番号順）
    // ただし、対抗は必ず含める、押さえは除外
    const taikouHorse = horses.find(h => h.role === '対抗');
    const taikouNumber = taikouHorse?.number;

    // 対抗以外の馬を馬番順で取得（押さえは除外）
    const otherHorses = horses
        .filter(h => h.number !== axisHorse.number)
        .filter(h => h.number !== taikouNumber)
        .filter(h => h.role !== '押さえ') // 押さえを除外
        .sort((a, b) => a.number - b.number) // 馬番順にソート
        .map(h => h.number)
        .filter(Boolean);

    // 対抗を優先し、残り枠に他の馬を追加（最大5頭）
    const opponents = [taikouNumber, ...otherHorses]
        .filter(Boolean)
        .slice(0, 5)
        .sort((a, b) => a - b); // 最終的に馬番順でソート

    return {
        axis: axisHorse.number,
        axisName: axisHorse.name,
        axisLabel: axisLabel,
        opponents: opponents,
        scoreDiff: taikou && honmei.score && taikou.score ? honmei.score - taikou.score : null
    };
}

