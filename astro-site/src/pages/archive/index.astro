---
export const prerender = true;
import archiveData10 from '../../data/archiveResults_2025-10.json';
import archiveData11 from '../../data/archiveResults_2025-11.json';
import archiveData12 from '../../data/archiveResults_2025-12.json';
import archiveData2026_01 from '../../data/archiveResults_2026-01.json';
import archiveData2026_02 from '../../data/archiveResults_2026-02.json';
import archiveData2026_03 from '../../data/archiveResults_2026-03.json';
import archiveData2026_04 from '../../data/archiveResults_2026-04.json';

// 全月のデータを統合
const archiveData = {
  '2025': {
    ...archiveData10['2025'],
    ...archiveData11['2025'],
    ...archiveData12['2025']
  },
  '2026': {
    ...archiveData2026_01['2026'],
    ...archiveData2026_02['2026'],
    ...archiveData2026_03['2026'],
    ...archiveData2026_04['2026']
  }
};

const years = Object.keys(archiveData).sort().reverse(); // 新しい順

// 年別統計計算
const yearSummaries = years.map(year => {
  const yearData = archiveData[year];
  const months = Object.keys(yearData).sort().reverse(); // 新しい順

  let perfectDays = 0;
  let totalPayout = 0;
  let totalHitRaces = 0;
  let totalRaces = 0;
  let totalDays = 0;

  months.forEach(month => {
    const monthData = yearData[month];
    const days = Object.keys(monthData);
    totalDays += days.length;

    days.forEach(day => {
      const dayData = monthData[day];
      if (dayData.perfectHit) perfectDays++;
      totalPayout += dayData.totalPayout || 0;
      totalHitRaces += dayData.hitRaces || 0;
      totalRaces += dayData.totalRaces || 0;
    });
  });

  const hitRate = totalRaces > 0 ? Math.round((totalHitRaces / totalRaces) * 100) : 0;

  // 最新の月を取得（直接遷移用）
  const latestMonth = months[0];

  return {
    year,
    latestMonth,
    perfectDays,
    payout: totalPayout,
    hitRaces: totalHitRaces,
    totalRaces,
    hitRate,
    daysCount: totalDays,
    monthsCount: months.length
  };
});
