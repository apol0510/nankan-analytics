---
export const prerender = true;
// プレミアムプラス専用ページ - 完全リニューアル版
// publicフォルダ画像直接参照方式（デプロイ不要）
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>プレミアムプラス - AIが導く最高確率の1鞍 | NANKANアナリティクス</title>
  <meta name="description" content="数万通りの買い目から厳選された、たった1つの答え。直近12戦9鞍的中、平均配当¥10,633の実績。">
  <meta name="robots" content="index, follow">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: #e2e8f0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      padding: 2rem 1rem;
      min-height: 100vh;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .header {
      text-align: center;
      margin-bottom: 3rem;
      padding: 2rem;
      background: rgba(30, 41, 59, 0.5);
      border-radius: 16px;
      border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .title {
      font-size: 2.5rem;
      font-weight: bold;
      color: #f59e0b;
      margin-bottom: 1rem;
      line-height: 1.3;
    }

    .subtitle {
      font-size: 1.3rem;
      color: #10b981;
      font-weight: 500;
      margin-bottom: 1rem;
    }

    .tagline {
      font-size: 1rem;
      color: #cbd5e1;
      max-width: 600px;
      margin: 0 auto;
    }

    .section {
      background: rgba(30, 41, 59, 0.8);
      border-radius: 16px;
      padding: 2.5rem;
      margin-bottom: 2rem;
      border: 1px solid rgba(100, 116, 139, 0.3);
    }

    .section-title {
      font-size: 1.8rem;
      font-weight: bold;
      color: #fbbf24;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-subtitle {
      font-size: 1rem;
      color: #94a3b8;
      margin-bottom: 2rem;
    }

    /* 実績画像グリッド */
    .results-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .result-image-card {
      background: rgba(15, 23, 42, 0.6);
      border-radius: 12px;
      padding: 0.8rem;
      border: 1px solid rgba(245, 158, 11, 0.3);
      transition: all 0.3s ease;
    }

    .result-image-card:hover {
      transform: translateY(-4px);
      border-color: rgba(245, 158, 11, 0.5);
      box-shadow: 0 8px 20px rgba(245, 158, 11, 0.2);
    }

    .result-image-card img {
      width: 100%;
      height: auto;
      border-radius: 8px;
      display: block;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .stat-box {
      background: rgba(59, 130, 246, 0.1);
      border: 1px solid rgba(59, 130, 246, 0.3);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }

    .stat-value {
      font-size: 2.5rem;
      font-weight: bold;
      color: #60a5fa;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 0.95rem;
      color: #94a3b8;
    }

    /* プラン比較 */
    .comparison-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      overflow: hidden;
      border-radius: 12px;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 1.2rem;
      text-align: left;
      border-bottom: 1px solid rgba(100, 116, 139, 0.2);
    }

    .comparison-table th {
      background: rgba(59, 130, 246, 0.2);
      color: #60a5fa;
      font-weight: 600;
    }

    .comparison-table td {
      background: rgba(15, 23, 42, 0.5);
    }

    .comparison-table .highlight {
      background: rgba(245, 158, 11, 0.1);
      font-weight: 600;
      color: #fbbf24;
    }

    .check-icon {
      color: #10b981;
      font-size: 1.2rem;
    }

    .cross-icon {
      color: #64748b;
      font-size: 1.2rem;
    }

    /* 価格正当性 */
    .value-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }

    .value-card {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(139, 92, 246, 0.3);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .value-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: #a78bfa;
      margin-bottom: 0.8rem;
    }

    .value-amount {
      font-size: 2rem;
      font-weight: bold;
      color: #fbbf24;
      margin-bottom: 0.5rem;
    }

    .value-amount.highlight-return {
      color: #fbbf24;
      font-size: 2rem;
      text-shadow: none;
    }

    .value-description {
      font-size: 0.9rem;
      color: #cbd5e1;
      line-height: 1.6;
    }

    /* リスク軽減 */
    .guarantee-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .guarantee-card {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.3);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .guarantee-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .guarantee-title {
      font-size: 1.2rem;
      font-weight: 600;
      color: #10b981;
      margin-bottom: 0.8rem;
    }

    .guarantee-text {
      font-size: 0.95rem;
      color: #cbd5e1;
      line-height: 1.6;
    }

    /* 社会的証明 */
    .testimonial-grid {
      display: grid;
      gap: 1.5rem;
    }

    .testimonial {
      background: rgba(15, 23, 42, 0.6);
      border-left: 4px solid #fbbf24;
      border-radius: 8px;
      padding: 1.5rem;
    }

    .testimonial-text {
      font-size: 1rem;
      color: #e2e8f0;
      line-height: 1.8;
      margin-bottom: 1rem;
      font-style: italic;
    }

    .testimonial-author {
      font-size: 0.9rem;
      color: #94a3b8;
      text-align: right;
    }

    /* 限定性 */
    .urgency-box {
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(245, 158, 11, 0.1));
      border: 2px solid rgba(245, 158, 11, 0.5);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
    }

    .urgency-title {
      font-size: 1.5rem;
      font-weight: bold;
      color: #fbbf24;
      margin-bottom: 1rem;
    }

    .urgency-text {
      font-size: 1.1rem;
      color: #e2e8f0;
      margin-bottom: 1rem;
    }

    .urgency-countdown {
      font-size: 2rem;
      font-weight: bold;
      color: #ef4444;
    }

    /* 的中実績画像（カード表示） */
    .image-card {
      background: rgba(30, 41, 59, 0.8);
      border-radius: 16px;
      padding: 2rem;
      border: 1px solid rgba(100, 116, 139, 0.3);
      text-align: center;
      margin-bottom: 2rem;
    }

    .image-card-title {
      font-size: 1.8rem;
      font-weight: bold;
      color: #fbbf24;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .hit-image {
      width: 100%;
      max-width: 600px;
      border-radius: 12px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(245, 158, 11, 0.3);
      margin: 0 auto;
      display: block;
    }

    /* CTA */
    .cta-section {
      background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(239, 68, 68, 0.2));
      border: 2px solid rgba(245, 158, 11, 0.5);
      border-radius: 16px;
      padding: 3rem;
      text-align: center;
      margin: 3rem 0;
    }

    .cta-title {
      font-size: 2rem;
      font-weight: bold;
      color: #fbbf24;
      margin-bottom: 1rem;
    }

    .cta-price {
      font-size: 3.5rem;
      font-weight: bold;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    .cta-note {
      font-size: 1rem;
      color: #cbd5e1;
      margin-bottom: 2rem;
    }

    .payment-methods {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 2rem;
    }

    .cta-button {
      background: linear-gradient(135deg, #10b981, #059669);
      color: #fff;
      padding: 1.8rem 4rem;
      font-size: 1.5rem;
      font-weight: bold;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 12px;
      transition: all 0.3s;
      box-shadow: 0 10px 30px rgba(16, 185, 129, 0.5);
    }

    .cta-button:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 40px rgba(16, 185, 129, 0.7);
    }

    .bank-transfer-button {
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      box-shadow: 0 10px 30px rgba(59, 130, 246, 0.5);
    }

    .bank-transfer-button:hover {
      box-shadow: 0 15px 40px rgba(59, 130, 246, 0.7);
    }

    /* 銀行振込モーダル */
    .bank-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.8);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .bank-modal.active {
      display: flex;
    }

    .bank-modal-content {
      background: linear-gradient(135deg, #1e293b, #0f172a);
      border: 2px solid rgba(59, 130, 246, 0.5);
      border-radius: 16px;
      padding: 2.5rem;
      max-width: 600px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
    }

    .bank-modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: rgba(239, 68, 68, 0.2);
      border: 1px solid rgba(239, 68, 68, 0.5);
      color: #ef4444;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      font-size: 1.5rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s;
    }

    .bank-modal-close:hover {
      background: rgba(239, 68, 68, 0.3);
      transform: rotate(90deg);
    }

    .bank-modal-title {
      font-size: 1.8rem;
      font-weight: bold;
      color: #60a5fa;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .bank-info-box {
      background: rgba(59, 130, 246, 0.1);
      border: 2px solid rgba(59, 130, 246, 0.3);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .bank-info-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem;
      background: rgba(15, 23, 42, 0.6);
      border-radius: 8px;
      margin-bottom: 1rem;
    }

    .bank-info-item:last-child {
      margin-bottom: 0;
    }

    .bank-info-label {
      color: #94a3b8;
      font-size: 0.95rem;
      font-weight: 500;
    }

    .bank-info-value {
      color: #e2e8f0;
      font-size: 1.1rem;
      font-weight: 600;
      text-align: right;
    }

    .bank-steps {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.3);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .bank-steps-title {
      font-size: 1.2rem;
      font-weight: bold;
      color: #10b981;
      margin-bottom: 1rem;
    }

    .bank-step {
      display: flex;
      gap: 12px;
      margin-bottom: 1rem;
      color: #cbd5e1;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .bank-step:last-child {
      margin-bottom: 0;
    }

    .bank-step-number {
      background: linear-gradient(135deg, #10b981, #059669);
      color: white;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 0.9rem;
      flex-shrink: 0;
    }

    .bank-warning {
      background: rgba(245, 158, 11, 0.1);
      border: 1px solid rgba(245, 158, 11, 0.3);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .bank-warning-title {
      font-size: 1.1rem;
      font-weight: bold;
      color: #fbbf24;
      margin-bottom: 0.8rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .bank-warning-text {
      color: #cbd5e1;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .copy-button {
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      color: white;
      border: none;
      padding: 6px 16px;
      border-radius: 6px;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.3s;
      margin-left: 8px;
    }

    .copy-button:hover {
      background: linear-gradient(135deg, #2563eb, #1e40af);
      transform: translateY(-2px);
    }

    /* 銀行振込フォーム */
    .bank-form-section {
      background: rgba(16, 185, 129, 0.05);
      border: 2px solid rgba(16, 185, 129, 0.3);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .bank-form-title {
      font-size: 1.3rem;
      font-weight: bold;
      color: #10b981;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .bank-form {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-label {
      color: #e2e8f0;
      font-size: 0.95rem;
      font-weight: 600;
    }

    .required {
      color: #ef4444;
      margin-left: 4px;
    }

    .form-input,
    .form-textarea {
      background: rgba(15, 23, 42, 0.8);
      border: 1px solid rgba(100, 116, 139, 0.3);
      border-radius: 8px;
      padding: 12px 16px;
      color: #e2e8f0;
      font-size: 1rem;
      transition: all 0.3s;
    }

    .form-input:focus,
    .form-textarea:focus {
      outline: none;
      border-color: rgba(16, 185, 129, 0.5);
      box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }

    .form-input::placeholder,
    .form-textarea::placeholder {
      color: #64748b;
    }

    .form-textarea {
      resize: vertical;
      min-height: 80px;
    }

    .form-hint {
      color: #94a3b8;
      font-size: 0.85rem;
      margin-top: 4px;
    }

    .form-submit-section {
      margin-top: 1rem;
    }

    .form-submit-button {
      width: 100%;
      background: linear-gradient(135deg, #10b981, #059669);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 16px 32px;
      font-size: 1.1rem;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .form-submit-button:hover:not(:disabled) {
      background: linear-gradient(135deg, #059669, #047857);
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(16, 185, 129, 0.4);
    }

    .form-submit-button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .form-message {
      margin-top: 1rem;
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 0.95rem;
      text-align: center;
    }

    .form-message.success {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.3);
      color: #10b981;
    }

    .form-message.error {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #ef4444;
    }

    .back-link {
      text-align: center;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(100, 116, 139, 0.3);
    }

    .back-link a {
      color: #60a5fa;
      text-decoration: none;
      font-size: 0.95rem;
      transition: color 0.3s;
    }

    .back-link a:hover {
      color: #3b82f6;
    }

    /* 痛みポイント */
    .pain-points {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .pain-item,
    .solution-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      background: rgba(15, 23, 42, 0.6);
      border-radius: 12px;
      padding: 1.5rem;
      border: 1px solid rgba(100, 116, 139, 0.3);
      transition: all 0.3s ease;
    }

    .pain-item:hover {
      border-color: rgba(239, 68, 68, 0.5);
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.1);
    }

    .solution-item {
      background: rgba(16, 185, 129, 0.1);
      border: 2px solid rgba(16, 185, 129, 0.5);
    }

    .solution-item:hover {
      border-color: rgba(16, 185, 129, 0.7);
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    }

    .pain-icon,
    .solution-icon {
      font-size: 2rem;
      flex-shrink: 0;
    }

    .pain-text strong,
    .solution-text strong {
      display: block;
      font-size: 1.1rem;
      color: #e2e8f0;
      margin-bottom: 0.5rem;
    }

    .solution-text strong {
      color: #10b981;
      font-size: 1.2rem;
    }

    .pain-text p,
    .solution-text p {
      font-size: 0.95rem;
      color: #94a3b8;
      margin: 0;
      line-height: 1.6;
    }

    .solution-text p {
      color: #cbd5e1;
    }

    /* 選択疲れ訴求 */
    .choice-fatigue-box {
      background: rgba(15, 23, 42, 0.8);
      border-radius: 12px;
      overflow: hidden;
    }

    .fatigue-quotes {
      background: rgba(239, 68, 68, 0.1);
      border-bottom: 2px solid rgba(239, 68, 68, 0.3);
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .quote-item {
      font-size: 1.2rem;
      color: #fca5a5;
      font-style: italic;
      padding: 1rem;
      background: rgba(15, 23, 42, 0.5);
      border-left: 3px solid #ef4444;
      border-radius: 8px;
    }

    .solution-banner {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(5, 150, 105, 0.1));
      padding: 2rem;
      text-align: center;
    }

    .solution-banner h3 {
      font-size: 1.5rem;
      color: #10b981;
      margin-bottom: 1rem;
    }

    .solution-banner p {
      font-size: 1.1rem;
      color: #e2e8f0;
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .solution-banner strong {
      color: #10b981;
      font-size: 1.2rem;
    }

    .solution-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 2rem;
    }

    .solution-stat {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .stat-number {
      font-size: 3rem;
      font-weight: bold;
      color: #10b981;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 0.95rem;
      color: #94a3b8;
    }

    /* 価格比較 */
    .price-comparison {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .plan-cost {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(100, 116, 139, 0.3);
      border-radius: 12px;
      padding: 2rem;
    }

    .plus-plan {
      background: rgba(16, 185, 129, 0.1);
      border: 2px solid rgba(16, 185, 129, 0.5);
    }

    .plan-cost h3 {
      font-size: 1.3rem;
      color: #60a5fa;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .plus-plan h3 {
      color: #10b981;
    }

    .cost-breakdown {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .cost-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.8rem;
      background: rgba(15, 23, 42, 0.5);
      border-radius: 8px;
    }

    .cost-item.success {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.3);
    }

