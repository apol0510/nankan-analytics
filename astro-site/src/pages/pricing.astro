---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="料金プラン - NANKANアナリティクス">
    <div class="pricing-page">
        <!-- ヘッダー -->
        <div class="pricing-header">
            <h1 class="pricing-title">
                🚀 <span class="gradient-text">AI予想で勝つ</span>
            </h1>
            <p class="pricing-subtitle">
                南関競馬専門のAI予想システム。あなたのスタイルに合わせたプランをお選びください。
            </p>
        </div>

        <!-- プラン比較カード -->
        <div class="plans-container">
            <!-- ライトプラン（Standard） -->
            <div class="plan-card">
                <div class="plan-header">
                    <h3 class="plan-name">ライト</h3>
                    <div class="plan-price">
                        <div class="price-strike">¥5,980</div>
                        <span class="price-amount">¥4,980</span>
                        <span class="price-period">/30日</span>
                    </div>
                    <p class="plan-description">まずは試したい方に</p>
                </div>

                <ul class="plan-features">
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span><strong>メインレース買い目</strong></span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>無料予想</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>高精度AI予想</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>サポート</span>
                    </li>
                </ul>

                <button class="plan-button plan-button-standard" onclick="openBankModal('Standard (ライト)', 4980, 'monthly')">
                    🏦 銀行振込で申し込む
                </button>
            </div>

            <!-- プレミアム買い切りプラン（中央・おすすめ）※一時非表示 -->
            <div class="plan-card plan-card-recommended" style="display: none;">
                <!-- 人気バッジ -->
                <div class="recommended-badge">
                    <span>🔥 今だけ特別価格</span>
                </div>

                <div class="plan-header">
                    <h3 class="plan-name">プレミアム買い切り</h3>
                    <div class="plan-price">
                        <div class="price-strike">¥108,000</div>
                        <span class="price-amount">¥78,000</span>
                        <div class="price-period-lifetime">永久アクセス</div>
                    </div>
                    <p class="plan-description">一度きりの支払いで永久に使える</p>
                </div>

                <ul class="plan-features">
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span><strong>永久アクセス（追加料金なし）</strong></span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span><strong>全レース（1R〜12R）の予想</strong></span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>高精度AI予想</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>詳細な投資戦略</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>優先サポート</span>
                    </li>
                </ul>

                <button class="plan-button plan-button-lifetime" onclick="openBankModal('Premium Lifetime', 78000, 'lifetime')">
                    🏦 銀行振込で申し込む
                </button>
            </div>

            <!-- プレミアム年払いプラン -->
            <div class="plan-card plan-card-recommended">
                <div class="recommended-badge">
                    <span>✨ お得</span>
                </div>
                <div class="plan-header">
                    <h3 class="plan-name">プレミアム年払い</h3>
                    <div class="plan-price">
                        <span class="price-amount">¥68,000</span>
                        <span class="price-period">/年</span>
                    </div>
                </div>

                <ul class="plan-features">
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span><strong>月額換算 ¥5,667/30日</strong></span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span><strong>全レース（1R〜12R）の予想</strong></span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>高精度AI予想</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>詳細な投資戦略</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>優先サポート</span>
                    </li>
                </ul>

                <button class="plan-button plan-button-annual" onclick="openBankModal('Premium Annual', 68000, 'annual')">
                    🏦 銀行振込で申し込む
                </button>
            </div>

            <!-- プレミアム月払いプラン -->
            <div class="plan-card">
                <div class="plan-header">
                    <h3 class="plan-name">プレミアム月払い</h3>
                    <div class="plan-price">
                        <span class="price-amount">¥18,000</span>
                        <span class="price-period">/30日</span>
                    </div>
                </div>

                <ul class="plan-features">
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span><strong>全レース（1R〜12R）の予想</strong></span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>高精度AI予想</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>詳細な投資戦略</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>優先サポート</span>
                    </li>
                </ul>

                <button class="plan-button plan-button-monthly" onclick="openBankModal('Premium Monthly', 18000, 'monthly')">
                    🏦 銀行振込で申し込む
                </button>
            </div>

            <!-- 無料プラン -->
            <div class="plan-card">
                <div class="plan-header">
                    <h3 class="plan-name">無料プラン</h3>
                    <div class="plan-price">
                        <span class="price-amount">¥0</span>
                    </div>
                    <p class="plan-description">お試ししたい方に</p>
                </div>

                <ul class="plan-features">
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>無料予想</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>基本的な競馬情報</span>
                    </li>
                    <li class="feature-item">
                        <span class="check-icon">✓</span>
                        <span>予想結果の確認</span>
                    </li>
                </ul>

                <a href="/free-signup/" class="plan-button plan-button-free">
                    無料会員登録
                </a>
            </div>
        </div>

        <!-- FAQ -->
        <div class="faq-section">
            <h2 class="faq-title">よくある質問</h2>
            
            <div class="faq-container">
                <div class="faq-item">
                    <h3 class="faq-question">Q: 無料プランでも予想は見れますか？</h3>
                    <p class="faq-answer">
                        はい。無料プランでも全レースの無料予想をご利用いただけます。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 支払い方法は何が利用できますか？</h3>
                    <p class="faq-answer">
                        現在、銀行振込のみ対応しております。振込後、入金確認取れ次第、即時にログイン情報をメールでお送りいたします。
                    </p>
                </div>

                <!-- 買い切り関連FAQ ※一時非表示
                <div class="faq-item">
                    <h3 class="faq-question">Q: 買い切りプランと年払い・月払いの違いは？</h3>
                    <p class="faq-answer">
                        <strong>【買い切りプラン】</strong><br>
                        ・¥78,000の一度きりの支払いで永久アクセス<br>
                        ・追加料金は一切かかりません<br>
                        ・AIは毎日進化し続けるため、長く使うほどお得<br><br>
                        <strong>【年払いプラン】</strong><br>
                        ・¥68,000/年（月額換算¥5,667）<br><br>
                        <strong>【月払いプラン】</strong><br>
                        ・¥18,000/30日<br>
                        ・いつでも解約可能
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 買い切りプランは本当に永久に使えますか？</h3>
                    <p class="faq-answer">
                        はい。一度ご購入いただければ、追加料金なしで永久にご利用いただけます。AIは毎日進化し続けるため、長く使うほどお得になります。50年間使えば月額換算¥130です。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 利用期間について教えてください</h3>
                    <p class="faq-answer">
                        <strong>【買い切りプラン】</strong>永久アクセス（追加料金なし）<br>
                        <strong>【年払いプラン】</strong>1年間（自動更新）<br>
                        <strong>【月払いプラン】</strong>1ヶ月ごとの自動更新
                    </p>
                </div>
                -->

                <div class="faq-item">
                    <h3 class="faq-question">Q: 利用開始までの流れは？</h3>
                    <p class="faq-answer">
                        ①お申し込みフォームから送信 → ②銀行振込 → ③入金確認後、ログイン情報をメールでお送りします。<br>
                        入金確認取れ次第、即時にご利用開始いただけます。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: 有効期限が切れたらどうなりますか？</h3>
                    <p class="faq-answer">
                        有効期限が近づきましたらメールでお知らせいたします。継続をご希望の場合は、再度お振込みいただくことでご利用を延長できます。
                    </p>
                </div>

                <div class="faq-item">
                    <h3 class="faq-question">Q: プランの変更はできますか？</h3>
                    <p class="faq-answer">
                        はい、可能です。ライトプランからプレミアムプランへのアップグレードなど、お気軽にご相談ください。
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- 銀行振込モーダル -->
    <div class="bank-modal" id="bankModal">
      <div class="bank-modal-content">
        <button class="bank-modal-close" onclick="closeBankModal()">×</button>

        <h2 class="bank-modal-title">🏦 銀行振込でのお申し込み</h2>
        <p class="modal-plan-info" id="modalPlanInfo"></p>

        <div class="bank-info-box">
          <div class="bank-info-item">
            <span class="bank-info-label">振込先銀行</span>
            <span class="bank-info-value">三井住友銀行
              <button class="copy-button" onclick="copyToClipboard('三井住友銀行')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">支店名</span>
            <span class="bank-info-value">洲本支店
              <button class="copy-button" onclick="copyToClipboard('洲本支店')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">口座種別</span>
            <span class="bank-info-value">普通</span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">口座番号</span>
            <span class="bank-info-value">5338892
              <button class="copy-button" onclick="copyToClipboard('5338892')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item">
            <span class="bank-info-label">口座名義</span>
            <span class="bank-info-value" style="font-size: 0.95rem;">ﾏ-ｸｱﾂﾌﾟｴ-ｱｲｻ-ﾋﾞｽ ｱｻｲ ﾄｼﾋﾛ
              <button class="copy-button" onclick="copyToClipboard('ﾏ-ｸｱﾂﾌﾟｴ-ｱｲｻ-ﾋﾞｽ ｱｻｲ ﾄｼﾋﾛ')">コピー</button>
            </span>
          </div>
          <div class="bank-info-item" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3);">
            <span class="bank-info-label">振込金額</span>
            <span class="bank-info-value" style="color: #10b981; font-size: 1.3rem;" id="modalAmount">¥5,980</span>
          </div>
        </div>

        <div class="bank-steps">
          <div class="bank-steps-title">📝 お申し込み手順</div>
          <div class="bank-step">
            <span class="bank-step-number">1</span>
            <span>上記の口座情報に振込金額をお振込みください</span>
          </div>
          <div class="bank-step">
            <span class="bank-step-number">2</span>
            <span>振込完了後、下記のフォームから必要情報をご送信ください</span>
          </div>
          <div class="bank-step">
            <span class="bank-step-number">3</span>
            <span>入金確認取れ次第、即時にログイン情報をメールでお送りいたします</span>
          </div>
        </div>

        <!-- 銀行振込申し込みフォーム -->
        <div class="bank-form-section">
          <div class="bank-form-title">💳 銀行振込完了フォーム</div>

          <form id="bankTransferForm" class="bank-form">
            <div class="form-group">
              <label for="fullName" class="form-label">お名前 <span class="required">*</span></label>
              <input type="text" id="fullName" name="fullName" class="form-input" required placeholder="山田 太郎">
            </div>

            <div class="form-group">
              <label for="email" class="form-label">メールアドレス <span class="required">*</span></label>
              <input type="email" id="email" name="email" class="form-input" required placeholder="example@email.com">
            </div>

            
            <div class="form-group">
                <label for="transferDate" class="form-label">振込完了日 <span class="required">*</span></label>
                <input type="date" id="transferDate" name="transferDate" class="form-input" required>
              </div>


            <div class="form-group">
              <label for="transferAmount" class="form-label">振込金額 <span class="required">*</span></label>
              <input type="number" id="transferAmount" name="transferAmount" class="form-input" required readonly>
            </div>

            <div class="form-group">
              <label for="remarks" class="form-label">備考・ご要望</label>
              <textarea id="remarks" name="remarks" class="form-input" rows="3" placeholder="何かご要望がありましたらご記入ください（任意）"></textarea>
            </div>

            <button type="submit" class="form-submit-button" id="submitButton">
              <span class="submit-text">📨 申し込みを送信</span>
              <span class="submit-loading" style="display: none;">送信中...</span>
            </button>

            <div class="form-message" id="formMessage" style="display: none;"></div>
          </form>
        </div>

        <div class="bank-warning">
          <div class="bank-warning-title">⚠️ ご注意事項</div>
          <div class="bank-warning-text">
            ・振込手数料はお客様負担となります<br>
            ・土日祝日の場合、確認が翌営業日となる場合がございます<br>
            ・<strong>お名前と同じ名義で振込をお願いします</strong><br>
            ・名義が異なる場合は、備考欄にその旨をご記入ください<br>
            ・ご入金後のキャンセル・返金は承っておりません
          </div>
        </div>
      </div>
    </div>
</BaseLayout>

<script is:inline>
  let currentPlan = '';
  let currentAmount = 0;
  let currentPlanType = 'monthly';

  function openBankModal(planName, amount, planType = 'monthly') {
    currentPlan = planName;
    currentAmount = amount;
    currentPlanType = planType;

    let periodText = '';
    if (planType === 'lifetime') {
      periodText = '（永久アクセス）';
    } else if (planType === 'annual') {
      periodText = '/年';
    } else {
      periodText = '/30日';
    }

    document.getElementById('modalPlanInfo').textContent = `プラン: ${planName} (¥${amount.toLocaleString()}${periodText})`;
    document.getElementById('modalAmount').textContent = `¥${amount.toLocaleString()}`;
    document.getElementById('transferAmount').value = amount;
    document.getElementById('bankModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeBankModal() {
    document.getElementById('bankModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function copyToClipboard(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();

    try {
      document.execCommand('copy');
      alert('コピーしました: ' + text);
    } catch (err) {
      console.error('コピーに失敗しました:', err);
    }

    document.body.removeChild(textarea);
  }

  // DOMContentLoaded後にフォーム処理を登録
  document.addEventListener('DOMContentLoaded', () => {
    // モーダル外クリックで閉じる
    document.addEventListener('click', (e) => {
      const bankModal = document.getElementById('bankModal');
      if (e.target === bankModal) {
        closeBankModal();
      }
    });

    // Escapeキーで閉じる
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeBankModal();
      }
    });

    // 銀行振込フォーム送信処理
    const bankTransferForm = document.getElementById('bankTransferForm');
    if (bankTransferForm) {
      bankTransferForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitButton = document.getElementById('submitButton');
        const submitText = submitButton.querySelector('.submit-text');
        const submitLoading = submitButton.querySelector('.submit-loading');
        const formMessage = document.getElementById('formMessage');

        submitButton.disabled = true;
        submitText.style.display = 'none';
        submitLoading.style.display = 'inline';
        formMessage.style.display = 'none';

        let periodText = '';
        if (currentPlanType === 'lifetime') {
          periodText = '（永久アクセス）';
        } else if (currentPlanType === 'annual') {
          periodText = '/年';
        } else {
          periodText = '/30日';
        }

        const formData = {
          fullName: document.getElementById('fullName').value,
          email: document.getElementById('email').value,
          transferDate: document.getElementById('transferDate').value,
          transferTime: "00:00",  // デフォルト値
          transferAmount: document.getElementById('transferAmount').value,
          transferName: document.getElementById('fullName').value,  // お名前と同じ
          remarks: document.getElementById('remarks').value,
          productName: `${currentPlan} (¥${currentAmount.toLocaleString()}${periodText})`,
          timestamp: new Date().toISOString()
        };

        try {
          const response = await fetch('/.netlify/functions/bank-transfer-application', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
            formMessage.textContent = '✅ お申し込みを受け付けました。確認メールをお送りしましたのでご確認ください。';
            formMessage.className = 'form-message success';
            formMessage.style.display = 'block';

            document.getElementById('bankTransferForm').reset();

            setTimeout(() => {
              closeBankModal();
              formMessage.style.display = 'none';
            }, 3000);
          } else {
            throw new Error(result.error || '送信に失敗しました');
          }
        } catch (error) {
          formMessage.textContent = '❌ エラーが発生しました: ' + error.message;
          formMessage.className = 'form-message error';
          formMessage.style.display = 'block';
        } finally {
          submitButton.disabled = false;
          submitText.style.display = 'inline';
          submitLoading.style.display = 'none';
        }
      });
    }
  });
</script>

<style>
    .pricing-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: #e2e8f0;
        padding: 2rem 1rem;
    }

    /* ヘッダー */
    .pricing-header {
        text-align: center;
        margin-bottom: 4rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .pricing-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .gradient-text {
        background: linear-gradient(to right, #3b82f6, #8b5cf6);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
    }

    .pricing-subtitle {
        font-size: 1.25rem;
        color: #94a3b8;
        line-height: 1.6;
    }

    /* プランカード */
    .plans-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        max-width: 1400px;
        margin: 0 auto 5rem auto;
    }

    @media (max-width: 1200px) {
        .plans-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .plan-card {
        background: rgba(30, 41, 59, 0.8);
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid rgba(51, 65, 85, 0.5);
        position: relative;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .plan-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        border-color: rgba(59, 130, 246, 0.5);
    }

    .plan-card-recommended {
        border: 2px solid #3b82f6;
        transform: scale(1.05);
        background: rgba(59, 130, 246, 0.1);
    }

    .recommended-badge {
        position: absolute;
        top: -1rem;
        left: 50%;
        transform: translateX(-50%);
        background: #3b82f6;
        color: white;
