<script>
    // Modal functionality
    document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('planSelectionModal');
        const openButton = document.getElementById('openPlanModal');
        const closeButton = document.getElementById('closePlanModal');

        // Open modal
        if (openButton) {
            openButton.addEventListener('click', function(e) {
                e.preventDefault();
                if (modal) {
                    modal.style.display = 'flex';
                }
            });
        }

        // Close modal
        if (closeButton) {
            closeButton.addEventListener('click', function() {
                if (modal) {
                    modal.style.display = 'none';
                }
            });
        }

        // Close modal when clicking outside
        if (modal) {
            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    modal.style.display = 'none';
                }
            });
        }

        // 🔒 三連複昨日の結果・アクセス制御（Standard/Premium会員のみ表示）
        const sanrenpukuResultsSection = document.getElementById('sanrenpuku-yesterday-results');
        if (sanrenpukuResultsSection) {
            // AccessControlコンポーネントと同じロジックでプラン取得
            let userPlan = null;

            // 1. test_subscription_*（本番で実際に使用中）
            const testSubscriptionKeys = Object.keys(localStorage).filter(key => key.startsWith('test_subscription_'));
            if (testSubscriptionKeys.length > 0) {
                try {
                    const testData = JSON.parse(localStorage.getItem(testSubscriptionKeys[0]));
                    userPlan = testData.planType;
                    console.log('📦 プラン検出（test_subscription）:', userPlan);
                } catch (error) {
                    console.error('Test subscription parsing error:', error);
                }
            }

            // 2. user-plan（新形式・JSON）
            if (!userPlan) {
                const userPlanData = localStorage.getItem('user-plan');
                if (userPlanData) {
                    try {
                        const userData = JSON.parse(userPlanData);
                        userPlan = userData.plan;
                        console.log('📦 プラン検出（user-plan）:', userPlan);
                    } catch (error) {
                        // JSON parseに失敗したら文字列として扱う
                        userPlan = userPlanData;
                        console.log('📦 プラン検出（user-plan・文字列）:', userPlan);
                    }
                }
            }

            // 3. userPlan（旧形式互換）
            if (!userPlan) {
                userPlan = localStorage.getItem('userPlan');
                console.log('📦 プラン検出（userPlan）:', userPlan);
            }

            console.log('🔍 最終プラン判定:', userPlan);

            // 🔧 2025-12-01修正: Premium会員・Premium Sanrenpuku会員のみ三連複結果を表示（Comboは非表示）
            // Standard/Premium（馬単プラン）は三連複アップセル用に表示
            // Premium Sanrenpukuは契約プランとして表示
            // Premium Comboは/premium-sanrenpuku/で閲覧（/premium-predictions/では非表示）
            if (userPlan === 'Standard' || userPlan === 'Premium' || userPlan === 'premium' ||
                userPlan === 'Premium Sanrenpuku') {
                sanrenpukuResultsSection.style.display = 'block';
                console.log('✅ 三連複昨日の結果表示: ' + userPlan + '会員');
            } else if (userPlan === 'Premium Combo') {
                console.log('🚫 三連複昨日の結果非表示: Premium Combo会員（/premium-sanrenpuku/で閲覧可能）');
            } else {
                console.log('🚫 三連複昨日の結果非表示: ' + (userPlan || '不明') + '（アクセス権限なし）');
            }
        }
    });

    // お問い合わせモーダル制御
    const contactModal = document.getElementById('contactModal');
    const contactForm = document.getElementById('contactForm');
    const contactSubmitButton = document.getElementById('contactSubmitButton');
    const contactFormMessage = document.getElementById('contactFormMessage');

    // モーダルを開く
    window.openContactModal = function() {
        contactModal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    };

    // モーダルを閉じる
    window.closeContactModal = function() {
        contactModal.style.display = 'none';
        document.body.style.overflow = 'auto';
        contactForm.reset();
        contactFormMessage.style.display = 'none';
    };

    // モーダル外クリックで閉じる
    contactModal.addEventListener('click', function(e) {
        if (e.target === contactModal) {
            closeContactModal();
        }
    });

    // Escapeキーで閉じる
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && contactModal.style.display === 'flex') {
            closeContactModal();
        }
    });

    // フォーム送信処理
    if (contactForm) {
        contactForm.addEventListener('submit', async function(e) {
            e.preventDefault();

            // ボタンを無効化・ローディング表示
            contactSubmitButton.disabled = true;
            contactSubmitButton.querySelector('.submit-text').style.display = 'none';
            contactSubmitButton.querySelector('.submit-loading').style.display = 'inline';

            const formData = {
                name: document.getElementById('contactName').value,
                email: document.getElementById('contactEmail').value,
                subject: document.getElementById('contactSubject').value,
                message: document.getElementById('contactMessage').value,
                formType: 'premium-predictions-contact',
                timestamp: new Date().toISOString()
            };

            try {
                const response = await fetch('/.netlify/functions/premium-plus-contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (response.ok) {
                    // 成功メッセージ表示
                    contactFormMessage.textContent = '✅ ' + (result.message || 'お問い合わせを受け付けました。確認メールをお送りしましたのでご確認ください。');
                    contactFormMessage.style.display = 'block';
                    contactFormMessage.style.color = '#10b981';
                    contactForm.reset();
                } else {
                    throw new Error(result.error || '送信に失敗しました');
                }
            } catch (error) {
                console.error('Contact form error:', error);
                contactFormMessage.textContent = '❌ 送信に失敗しました。もう一度お試しいただくか、support@keiba.link までご連絡ください。';
                contactFormMessage.style.display = 'block';
                contactFormMessage.style.color = '#ef4444';
            } finally {
                // ボタンを有効化・通常表示に戻す
                contactSubmitButton.disabled = false;
                contactSubmitButton.querySelector('.submit-text').style.display = 'inline';
                contactSubmitButton.querySelector('.submit-loading').style.display = 'none';
            }
        });
    }
</script>

